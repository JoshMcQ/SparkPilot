SPARKPILOT_ENVIRONMENT=dev
SPARKPILOT_ENV=dev
SPARKPILOT_DATABASE_URL=postgresql+psycopg://sparkpilot:sparkpilot@localhost:5432/sparkpilot
SPARKPILOT_DRY_RUN_MODE=false
SPARKPILOT_ENABLE_FULL_BYOC_MODE=false
SPARKPILOT_AUTH_MODE=oidc
# Customer pool (new canonical vars)
SPARKPILOT_CUSTOMER_OIDC_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_customer_pool
SPARKPILOT_CUSTOMER_OIDC_AUDIENCE=replace-with-customer-app-client-id
SPARKPILOT_CUSTOMER_OIDC_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_customer_pool/.well-known/jwks.json
# Internal pool (required)
SPARKPILOT_INTERNAL_OIDC_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_internal_pool
SPARKPILOT_INTERNAL_OIDC_AUDIENCE=replace-with-internal-app-client-id
SPARKPILOT_INTERNAL_OIDC_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_internal_pool/.well-known/jwks.json
SPARKPILOT_INVITE_EMAIL_FROM="SparkPilot <invites@example.invalid>"
SPARKPILOT_INVITE_EMAIL_REPLY_TO=
SPARKPILOT_INVITE_EMAIL_TIMEOUT_SECONDS=10
# Legacy customer aliases retained for expand-contract migration (phase 1 only).
SPARKPILOT_OIDC_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
SPARKPILOT_OIDC_AUDIENCE=replace-with-cognito-app-client-id
SPARKPILOT_OIDC_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example/.well-known/jwks.json
SPARKPILOT_BOOTSTRAP_SECRET=replace-with-strong-bootstrap-secret
SPARKPILOT_BOOTSTRAP_FLOW=enabled
SPARKPILOT_INTERNAL_ADMINS=
SPARKPILOT_COGNITO_HOSTED_UI_URL=https://your-cognito-domain.auth.us-east-1.amazoncognito.com/oauth2/authorize
# Include public-site origin (port 3001 in dev) so the contact form can POST
SPARKPILOT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
SPARKPILOT_CRM_WEBHOOK_URL=
SPARKPILOT_RESEND_API_KEY=
SPARKPILOT_MAGIC_LINK_TTL_HOURS=24
SPARKPILOT_AWS_REGION=us-east-1
SPARKPILOT_LOG_GROUP_PREFIX=/sparkpilot/runs
SPARKPILOT_EMR_RELEASE_LABEL=emr-7.10.0-latest
SPARKPILOT_EMR_EXECUTION_ROLE_ARN=arn:aws:iam::111111111111:role/SparkPilotEmrExecutionRole
SPARKPILOT_ASSUME_ROLE_EXTERNAL_ID=
SPARKPILOT_QUEUE_BATCH_SIZE=20
SPARKPILOT_POLL_INTERVAL_SECONDS=15
SPARKPILOT_PRICING_VCPU_USD_PER_SECOND=0.000011244
SPARKPILOT_PRICING_MEMORY_GB_USD_PER_SECOND=0.000001235
SPARKPILOT_PRICING_ARM64_DISCOUNT_PCT=20
SPARKPILOT_PRICING_MIXED_DISCOUNT_PCT=10
SPARKPILOT_PRICING_SOURCE=auto
SPARKPILOT_PRICING_CACHE_SECONDS=21600
OIDC_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
OIDC_AUDIENCE=replace-with-cognito-app-client-id
OIDC_CLIENT_ID=replace-with-ui-server-client-id
OIDC_CLIENT_SECRET=replace-with-ui-server-client-secret
OIDC_TOKEN_ENDPOINT=https://sparkpilot-auth.auth.us-east-1.amazoncognito.com/oauth2/token
SPARKPILOT_API=http://localhost:8000
SPARKPILOT_TERRAFORM_STATE_BUCKET=
SPARKPILOT_TERRAFORM_STATE_REGION=us-east-1
SPARKPILOT_TERRAFORM_STATE_LOCK_TABLE=
SPARKPILOT_TERRAFORM_STATE_ROLE_ARN=
